# === Environment files ===
/.env
.env
.env.*
*.env
.env.template
.venv*/
venv*/
.dagshub_tokens
/.aws

# === Backup / temp files ===
/backup_*
backup*/
*.tmp
*.temp
*.bak
*.pid
tmp/

# === DVC cache & temp files (big, keep out of Git) ===
.dvc/cache/
.dvc/tmp/

# DO NOT ignore DVC metadata/config – keep them in Git
!.dvc
!.dvc/**
!*.dvc
!dvc.yaml
!dvc.lock

# === Large data & artifacts (handled by DVC, not Git) ===
data/
artifacts/
plots/
metrics.json
data-file.bin

# BUT: never ignore DVC metafiles, even inside data/ or nested dirs
!data/*.dvc
!data/**/*.dvc
!artifacts.dvc
!artifacts/*.dvc
!plots.dvc
!plots/*.dvc

# === Python ===
__pycache__/
*.pyc
*.pyo
*.pyd

# === Airflow ===
airflow/logs/
airflow-webserver.pid
airflow/airflow_init.sh
airflow/__pycache__/
airflow/dags/__pycache__/

# === OS / editor files ===
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*.swo

# === Docker ===
docker-compose.override.yml
docker-compose.override.yaml

# === Logs / temp folders ===
logs/

# === Misc project-specific ===
predict-api/deployment/
monitoring/alertmanager.yml
