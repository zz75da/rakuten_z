# === Python cache ===
__pycache__/
*.pyc
*.pyo
*.pyd

# === Feature cache ===
data/feature_cache/

# === Logs and temporary backups ===
airflow/logs/
logs/
data/artifacts/logs/
backup*/
*.tmp
*.swp
*.bak
*.temp
*.pid
*.log

# === Git ignored files ===
.git/
.gitignore
data/.gitignore

# === Environment / secret files ===
*.env
*.env.*
.env
.env.local
.env.template
.dagshub_tokens

# === Airflow temp files ===
airflow-webserver.pid
airflow/dags/__pycache__/
airflow/logs/


# === Temporary artifacts (NOT tracked by DVC) ===
data/artifacts_from_container/
data/artifacts/temp/

# === System / editor files ===
.DS_Store
Thumbs.db
.vscode/
.idea/
.venv*/
venv*/
*.swo
*.swp

# === Docker-related files ===
*.dockerignore
docker-compose.override.yml

# IMPORTANT: DO *NOT* ignore .dvc/config or .dvc/cache here
# Let DVC manage its internal metadata
