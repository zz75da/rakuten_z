{
  "name": "Rakuten MLOps Dev (multi-service)",
  "dockerComposeFile": "../docker-compose.yml",
  "service": "train-api",
  "workspaceFolder": "/app",
  "runServices": [],
  "shutdownAction": "stopCompose",
  "updateRemoteUserUID": true,
  "remoteUser": "root",

  "features": {
    "ghcr.io/devcontainers/features/docker-in-docker:2": {}
  },

  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "ms-azuretools.vscode-docker",
        "ms-vscode-remote.remote-containers"
      ]
    }
  },

  "overrideCommand": false,
  "postCreateCommand": "echo '✅ Dev Container ready! Use Command Palette → Dev Containers: Open Service Container'"
}
